# ============================================================
# .env.all - Dual Chain Configuration (TRON + 0G / ZeroGravity)
# Usage: ENV_FILE=.env.all node server/server.js
# ============================================================

NODE_ENV=development

# ============ Server Configuration ============
SERVER_PORT=7778
JWT_SECRET=your_jwt_secret_here
MONGODB_URI=mongodb://localhost:27017/bridge-poker
BLOCKCHAIN_ENABLED=true

# ============ Multi-chain Mode ============
# Options: 'tron' (TRON only) | '0g' (0G only) | 'both' (dual chain)
BLOCKCHAIN_MODE=both

# ===========================================
# TRON Blockchain Configuration
# ===========================================
TRONGRID_API_KEY=b9ffe304-85f2-4ba1-ad7a-d51c4f87c290
TRON_NETWORK=testnet

TESTNET_PRIVATE_KEY=b185b511ad8314b5cf787108676581223ce354321428f6efb46ef2370c882905
TESTNET_CONTRACT_ADDRESS=TQiG3UXV9uSLyW5Ax7Pa9WwcT9EhEJnU4c

NILE_PRIVATE_KEY=b185b511ad8314b5cf787108676581223ce354321428f6efb46ef2370c882905

NFT_CONTRACT_ADDRESS=TXiaxLfirc3bMTT8uJjesBAW2Vvx1VABcC
NFT_CONTRACT_ONCHAIN=TXiaxLfirc3bMTT8uJjesBAW2Vvx1VABcC

SERVER_PRIVATE_KEY=b185b511ad8314b5cf787108676581223ce354321428f6efb46ef2370c882905
NFT_SIGNER_ADDRESS=TW2BxbsK6VoqMiotWuc56gsupF6gaEsXuA

