# 0G Feature Flags
ZEROG_MOCK=false
SETTLEMENT_FALLBACK_ENABLED=true

# ============ AI Configuration ============
AI_ENABLED=true
AI_DEFAULT_DIFFICULTY=medium
AI_MAX_PLAYERS_PER_TABLE=3
AI_PROCESS_PATH=python3
AI_SCRIPT=ai_engine/decision_engine.py
