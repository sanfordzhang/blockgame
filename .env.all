STAKING_CONTRACT_ADDRESS=TBz2FDnQtfAqUfjeZhcTTKhuC15SHqXmdc

# CHIP Token & AMM
CHIP_TOKEN_ADDRESS=TFWScXGFALnK9D79zf5Jrnw5on7aqJiaY3
AMM_POOL_ADDRESS=TDoYGYAgPLrWTSjsANUuAjEFaAKr3oBo3v
AMM_ROUTER_ADDRESS=TXfeHckcmZeigv1ixUyFkTc9q7NHNGfcPJ
CHIP_DAILY_REWARD_LIMIT=5000
CHIP_RESERVE_TARGET=500000

# ===========================================
# 0G (ZeroGravity) EVM Blockchain Configuration
# ===========================================
ZEROG_ENABLED=true
ZEROG_RPC_URL=https://evmrpc-galileo.0g.ai
ZEROG_PRIVATE_KEY=0xb7a2d80e6eec2cd669b44ec42aa291fbd65fe53ed2050b346d40cbea1712bf1e
