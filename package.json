    "scripts": {
        "start": "node server/server.js | react-scripts --openssl-legacy-provider start",
        "start:server": "node server/server.js",
        "start:client": "react-scripts --openssl-legacy-provider start",
        "build": "node server/server.js | react-scripts --openssl-legacy-provider build",
        "test": "node server/server.js | react-scripts --openssl-legacy-provider test",
        "test:contracts": "hardhat test tests/contracts/*.test.js",
        "test:services": "mocha tests/services/*.test.js --timeout 10000",
        "test:api": "mocha tests/api/*.test.js --timeout 10000",
        "test:integration": "mocha tests/integration/*.test.js --timeout 30000",
        "test:bot": "mocha tests/bot/*.test.js --timeout 30000",
        "test:performance": "mocha tests/performance/*.test.js --timeout 120000",
        "test:security": "mocha tests/security/*.test.js --timeout 30000",
        "test:e2e": "playwright test tests/e2e",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug",
        "test:coverage": "nyc --reporter=lcov --reporter=text mocha 'tests/**/*.test.js' --timeout 30000",
        "test:all": "npm run test:contracts && npm run test:services && npm run test:api && npm run test:integration && npm run test:e2e",
        "test:quick": "npm run test:services && npm run test:api",
        "eject": "node server/server.js | react-scripts --openssl-legacy-provider eject"
    },
    "eslintConfig": {
        "extends": "react-app"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "proxy": "http://localhost:7778"
