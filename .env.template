# ===========================================
# TRON Blockchain Configuration
# ===========================================

# TronGrid API Key (get from https://www.trongrid.io/)
TRONGRID_API_KEY=your_trongrid_api_key_here

# ===========================================
# Testnet Configuration (Fun Mode)
# ===========================================
TESTNET_PRIVATE_KEY=your_testnet_private_key_here
TESTNET_CONTRACT_ADDRESS=

# ===========================================
# Mainnet Configuration (Real Mode)
# ===========================================
MAINNET_PRIVATE_KEY=your_mainnet_private_key_here
MAINNET_CONTRACT_ADDRESS=

# ===========================================
# Development/Local Configuration
# ===========================================
DEV_PRIVATE_KEY=
DEV_CONTRACT_ADDRESS=

# ===========================================
# Backend Server Configuration
# ===========================================
PORT=7777
JWT_SECRET=your_jwt_secret_here
MONGODB_URI=mongodb://localhost:27017/bridge-poker
# Additional allowed browser origins, comma-separated.
# Example: CORS_ORIGINS=https://app.example.com,https://staging.example.com
CORS_ORIGINS=
# Runtime public host for reusable deployments. Prefer passing this in the shell,
# PM2 ecosystem, or deployment script instead of hardcoding server IPs here.
# Example: SERVER_HOST=app.example.com
SERVER_HOST=
PUBLIC_HOST=
SERVER_HOSTNAME=
NFT_PUBLIC_BASE_URL=
PUBLIC_API_BASE_URL=

# ===========================================
# Admin Configuration
# ===========================================
ADMIN_ADDRESS=your_admin_wallet_address_here

# ===========================================
# Game Configuration
# ===========================================
# Min buy-in in TRX (default: 10)
MIN_BUY_IN=10
# Max buy-in in TRX (default: 1000)
MAX_BUY_IN=1000
# Initial rake rate in basis points (default: 250 = 2.5%)
INITIAL_RAKE_RATE=250

# ===========================================
# Server Wallet Configuration
# ===========================================
# Server wallet private key for signing NFT claims and tournament operations
SERVER_PRIVATE_KEY=your_server_private_key_here
# Server wallet address (derived from SERVER_PRIVATE_KEY)
SERVER_WALLET_ADDRESS=

# ===========================================
# Tournament Contract Configuration
# ===========================================
TOURNAMENT_CONTRACT_ADDRESS=
NILE_TOURNAMENT_CONTRACT=
MAINNET_TOURNAMENT_CONTRACT=

# ===========================================
# NFT Achievement Contract Configuration
# ===========================================
NFT_CONTRACT_ADDRESS=
NILE_NFT_CONTRACT=
MAINNET_NFT_CONTRACT=
# Base URI for NFT metadata
NFT_BASE_URI=https://api.example.com/nft/
# NFT mint price in TRX (default: 5)
NFT_MINT_PRICE=5
# NFT signature validity in seconds (default: 7 days)
NFT_SIGNATURE_VALIDITY=604800

# ===========================================
# CHIP Token Contract Configuration
# ===========================================
CHIP_TOKEN_ADDRESS=
NILE_CHIP_TOKEN=
MAINNET_CHIP_TOKEN=
# Total supply: 1,000,000,000 CHIP
CHIP_MAX_SUPPLY=100000000000000000

# ===========================================
# Staking Contract Configuration
# ===========================================
STAKING_CONTRACT_ADDRESS=
NILE_STAKING_CONTRACT=
MAINNET_STAKING_CONTRACT=
# Minimum stake in CHIP (default: 100)
STAKING_MIN_STAKE=100
# Minimum lock duration in days (default: 7)
STAKING_MIN_LOCK_DAYS=7
# Maximum lock duration in days (default: 365)
STAKING_MAX_LOCK_DAYS=365
# Early unstake penalty percentage (default: 10)
STAKING_EARLY_UNSTAKE_PENALTY=10

# ===========================================
# DAO Governance Contract Configuration
# ===========================================
GOVERNANCE_CONTRACT_ADDRESS=
NILE_GOVERNANCE_CONTRACT=
MAINNET_GOVERNANCE_CONTRACT=
# Proposal threshold in CHIP (default: 1000)
DAO_PROPOSAL_THRESHOLD=100000000000
# Quorum percentage (default: 10)
DAO_QUORUM_PERCENT=10
# Voting period in days (default: 3)
DAO_VOTING_PERIOD_DAYS=3

# ===========================================
# Testnet Configuration (Shasta)
# ===========================================
SHASTA_PRIVATE_KEY=
SHASTA_TOURNAMENT_CONTRACT=
SHASTA_NFT_CONTRACT=
SHASTA_CHIP_TOKEN=
SHASTA_STAKING_CONTRACT=
SHASTA_GOVERNANCE_CONTRACT=
